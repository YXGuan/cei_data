NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# CEI-specific backend/import aliases. These avoid collisions with other Supabase projects.
SUPABASE_URL_CEI=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY_CEI=your-publishable-key

# Local imports only. Never expose this value through NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY_CEI=your-service-role-key

# Only needed by `cei-data upload-hf`.
HF_TOKEN=your-hugging-face-token
